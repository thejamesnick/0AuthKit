{
  "name": "0authkit",
  "version": "1.0.0",
  "description": "Add OAuth to any app in minutes. Bring your own credentials.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest --run --exclude \"dist/**\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thejamesnick/0AuthKit.git"
  },
  "homepage": "https://github.com/thejamesnick/0AuthKit",
  "bugs": {
    "url": "https://github.com/thejamesnick/0AuthKit/issues"
  },
  "keywords": [
    "oauth",
    "oauth2",
    "auth",
    "authentication",
    "google",
    "github",
    "sdk",
    "pkce",
    "typescript",
    "browser",
    "node"
  ],
  "author": "thejamesnick",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
